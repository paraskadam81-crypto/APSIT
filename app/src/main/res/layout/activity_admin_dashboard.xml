<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_background"
    tools:context=".AdminDashboardActivity">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER SECTION -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/header_background">

                <View
                    android:id="@+id/ivAdminAvatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="32dp"
                    android:background="@drawable/circle_avatar_gold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="A"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/ivAdminAvatar"
                    app:layout_constraintEnd_toEndOf="@id/ivAdminAvatar"
                    app:layout_constraintStart_toStartOf="@id/ivAdminAvatar"
                    app:layout_constraintTop_toTopOf="@id/ivAdminAvatar" />

                <TextView
                    android:id="@+id/tvAdminTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Admin Dashboard"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="@id/ivAdminAvatar"
                    app:layout_constraintTop_toBottomOf="@id/ivAdminAvatar" />

                <TextView
                    android:id="@+id/tvCanteenSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="APSIT Canteen"
                    android:textColor="@color/admin_primary_light"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="@id/tvAdminTitle"
                    app:layout_constraintTop_toBottomOf="@id/tvAdminTitle" />

                <ImageView
                    android:id="@+id/btnLogout"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:src="@android:drawable/ic_lock_power_off"
                    app:layout_constraintBottom_toBottomOf="@id/ivAdminAvatar"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/ivAdminAvatar"
                    app:tint="@color/white" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="-40dp"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- STAT CARDS GRID -->
                <GridLayout
                    android:id="@+id/statsGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:rowCount="2">

                    <!-- Today's Orders -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_avatar_gold"
                                android:backgroundTint="@color/stat_orders_bg">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_cart"
                                    app:tint="@color/stat_orders_icon" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvTodayOrders"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="0"
                                android:textColor="@color/admin_text_primary"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Today's Orders"
                                android:textColor="@color/admin_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_gravity="bottom"
                            android:background="@color/stat_orders_icon" />
                    </androidx.cardview.widget.CardView>

                    <!-- Today's Revenue -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_avatar_gold"
                                android:backgroundTint="@color/stat_revenue_bg">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_revenue"
                                    app:tint="@color/stat_revenue_icon" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvTodayRevenue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="₹0"
                                android:textColor="@color/admin_text_primary"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Today's Revenue"
                                android:textColor="@color/admin_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_gravity="bottom"
                            android:background="@color/stat_revenue_icon" />
                    </androidx.cardview.widget.CardView>

                    <!-- Pending Orders -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_avatar_gold"
                                android:backgroundTint="@color/stat_pending_bg">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_hourglass"
                                    app:tint="@color/stat_pending_icon" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvPendingOrders"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="0"
                                android:textColor="@color/admin_text_primary"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending Orders"
                                android:textColor="@color/admin_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_gravity="bottom"
                            android:background="@color/stat_pending_icon" />
                    </androidx.cardview.widget.CardView>

                    <!-- Low Stock Items -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <FrameLayout
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@drawable/circle_avatar_gold"
                                android:backgroundTint="@color/stat_low_stock_bg">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_warning"
                                    app:tint="@color/stat_low_stock_icon" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvLowStock"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="0"
                                android:textColor="@color/admin_text_primary"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Low Stock Items"
                                android:textColor="@color/admin_text_secondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_gravity="bottom"
                            android:background="@color/stat_low_stock_icon" />
                    </androidx.cardview.widget.CardView>
                </GridLayout>

                <!-- ORDERS BY STATUS SECTION -->
                <TextView
                    android:id="@+id/tvStatusTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Orders by Status"
                    android:textColor="@color/admin_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp">

                    <LinearLayout
                        android:id="@+id/statusList"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Pending Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@color/status_pending" />
                            <TextView android:id="@+id/badgePending" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Pending" android:textColor="@color/admin_text_primary" android:textSize="14sp" />
                            <TextView android:id="@+id/tvPendingCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_badge_pending" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:text="0" android:textColor="@color/pill_pending_text" android:textStyle="bold" />
                            <ProgressBar android:id="@+id/pbPending" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/admin_divider" />

                        <!-- Preparing Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@color/status_preparing" />
                            <TextView android:id="@+id/badgePreparing" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Preparing" android:textColor="@color/admin_text_primary" android:textSize="14sp" />
                            <TextView android:id="@+id/tvPreparingCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_badge_preparing" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:text="0" android:textColor="@color/pill_preparing_text" android:textStyle="bold" />
                            <ProgressBar android:id="@+id/pbPreparing" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/admin_divider" />

                        <!-- Ready Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@color/status_ready" />
                            <TextView android:id="@+id/badgeReady" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Ready" android:textColor="@color/admin_text_primary" android:textSize="14sp" />
                            <TextView android:id="@+id/tvReadyCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_badge_ready" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:text="0" android:textColor="@color/pill_ready_text" android:textStyle="bold" />
                            <ProgressBar android:id="@+id/pbReady" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        </LinearLayout>
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/admin_divider" />

                        <!-- Completed Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">
                            <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@color/status_completed" />
                            <TextView android:id="@+id/badgeCompleted" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:layout_marginStart="12dp" android:text="Completed" android:textColor="@color/admin_text_primary" android:textSize="14sp" />
                            <TextView android:id="@+id/tvCompletedCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_badge_completed" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:text="0" android:textColor="@color/pill_completed_text" android:textStyle="bold" />
                            <ProgressBar android:id="@+id/pbCompleted" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- QUICK ACCESS SECTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Quick Access"
                    android:textColor="@color/admin_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <GridLayout
                    android:id="@+id/quickAccessGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:columnCount="2">

                    <!-- Menu Items -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardMenuManagement"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/ripple_card"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:gravity="center"
                                android:orientation="vertical">
                                <FrameLayout
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:background="@drawable/gradient_circle_amber">
                                    <ImageView
                                        android:layout_width="30dp"
                                        android:layout_height="30dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_restaurant_menu"
                                        app:tint="@color/white" />
                                </FrameLayout>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Menu Items"
                                    android:textColor="@color/admin_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignParentBottom="true"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="12dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="#BDBDBD" />
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Orders -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardOrderManagement"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/ripple_card"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:gravity="center"
                                android:orientation="vertical">
                                <FrameLayout
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:background="@drawable/gradient_circle_green">
                                    <ImageView
                                        android:layout_width="30dp"
                                        android:layout_height="30dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_receipt_long"
                                        app:tint="@color/white" />
                                </FrameLayout>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Orders"
                                    android:textColor="@color/admin_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignParentBottom="true"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="12dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="#BDBDBD" />
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Inventory -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardInventory"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/ripple_card"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:gravity="center"
                                android:orientation="vertical">
                                <FrameLayout
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:background="@drawable/gradient_circle_teal">
                                    <ImageView
                                        android:layout_width="30dp"
                                        android:layout_height="30dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_inventory"
                                        app:tint="@color/white" />
                                </FrameLayout>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Inventory"
                                    android:textColor="@color/admin_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignParentBottom="true"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="12dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="#BDBDBD" />
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Reports -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/cardReports"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_margin="6dp"
                        android:layout_columnWeight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="@drawable/ripple_card"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:gravity="center"
                                android:orientation="vertical">
                                <FrameLayout
                                    android:layout_width="64dp"
                                    android:layout_height="64dp"
                                    android:background="@drawable/gradient_circle_blue">
                                    <ImageView
                                        android:layout_width="30dp"
                                        android:layout_height="30dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_bar_chart"
                                        app:tint="@color/white" />
                                </FrameLayout>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Reports"
                                    android:textColor="@color/admin_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignParentBottom="true"
                                android:layout_alignParentEnd="true"
                                android:layout_margin="12dp"
                                android:src="@drawable/ic_chevron_right"
                                app:tint="#BDBDBD" />
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>
                </GridLayout>

                <!-- RECENT ORDERS SECTION -->
                <RelativeLayout
                    android:id="@+id/rlRecentTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recent Orders"
                        android:textColor="@color/admin_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvViewAllOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="View All"
                        android:textColor="@color/admin_accent"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/recentOrdersContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

