<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F0">

    <!-- TOOLBAR -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#1B4332"
        android:paddingHorizontal="16dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Dashboard"
                android:textColor="#D4A017"
                android:textSize="20sp"
                android:fontFamily="serif"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APSIT Canteen"
                android:textColor="#B3FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnLogout"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_lock_power_off"
            app:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- SECTION A: Stats Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2">

                <!-- Card 1: Today's Orders -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvTodayOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#D4A017"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Orders"
                        android:textColor="#5A5A5A"
                        android:textSize="12sp" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="8dp"
                        android:background="#D4A017" />
                </LinearLayout>

                <!-- Card 2: Today's Revenue -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvTodayRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textColor="#D4A017"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Revenue"
                        android:textColor="#5A5A5A"
                        android:textSize="12sp" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="8dp"
                        android:background="#D4A017" />
                </LinearLayout>

                <!-- Card 3: Pending Orders -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvPendingOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#D4A017"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending Orders"
                        android:textColor="#5A5A5A"
                        android:textSize="12sp" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="8dp"
                        android:background="#D4A017" />
                </LinearLayout>

                <!-- Card 4: Low Stock -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvLowStock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#D4A017"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Low Stock Items"
                        android:textColor="#5A5A5A"
                        android:textSize="12sp" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:layout_marginTop="8dp"
                        android:background="#D4A017" />
                </LinearLayout>
            </GridLayout>

            <!-- SECTION B: Order Status Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_admin_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Orders by Status"
                    android:textColor="#1B4332"
                    android:textSize="16sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />

                <!-- Row: Pending -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/badgePending" android:layout_width="70dp" android:layout_height="wrap_content" android:text="Pending" android:gravity="center" android:padding="4dp" android:textSize="10sp" android:background="@drawable/bg_badge_pending" android:textColor="#856404"/>
                    <TextView android:id="@+id/tvPendingCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0" android:textColor="#1A1A1A"/>
                    <ProgressBar android:id="@+id/pbPending" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_toEndOf="@id/badgePending" android:layout_toStartOf="@id/tvPendingCount" android:layout_centerVertical="true" android:layout_marginHorizontal="8dp" android:progressTint="#F0C040" android:progressBackgroundTint="#D8F3DC" />
                </RelativeLayout>

                <!-- Row: Preparing -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/badgePreparing" android:layout_width="70dp" android:layout_height="wrap_content" android:text="Preparing" android:gravity="center" android:padding="4dp" android:textSize="10sp" android:background="@drawable/bg_badge_preparing" android:textColor="#0C5460"/>
                    <TextView android:id="@+id/tvPreparingCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0" android:textColor="#1A1A1A"/>
                    <ProgressBar android:id="@+id/pbPreparing" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_toEndOf="@id/badgePreparing" android:layout_toStartOf="@id/tvPreparingCount" android:layout_centerVertical="true" android:layout_marginHorizontal="8dp" android:progressTint="#378ADD" android:progressBackgroundTint="#D8F3DC" />
                </RelativeLayout>

                <!-- Row: Ready -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/badgeReady" android:layout_width="70dp" android:layout_height="wrap_content" android:text="Ready" android:gravity="center" android:padding="4dp" android:textSize="10sp" android:background="@drawable/bg_badge_ready" android:textColor="#155724"/>
                    <TextView android:id="@+id/tvReadyCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0" android:textColor="#1A1A1A"/>
                    <ProgressBar android:id="@+id/pbReady" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_toEndOf="@id/badgeReady" android:layout_toStartOf="@id/tvReadyCount" android:layout_centerVertical="true" android:layout_marginHorizontal="8dp" android:progressTint="#2D6A4F" android:progressBackgroundTint="#D8F3DC" />
                </RelativeLayout>

                <!-- Row: Completed -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                    <TextView android:id="@+id/badgeCompleted" android:layout_width="70dp" android:layout_height="wrap_content" android:text="Completed" android:gravity="center" android:padding="4dp" android:textSize="10sp" android:background="@drawable/bg_badge_completed" android:textColor="#F0C040"/>
                    <TextView android:id="@+id/tvCompletedCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0" android:textColor="#1A1A1A"/>
                    <ProgressBar android:id="@+id/pbCompleted" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_toEndOf="@id/badgeCompleted" android:layout_toStartOf="@id/tvCompletedCount" android:layout_centerVertical="true" android:layout_marginHorizontal="8dp" android:progressTint="#1B4332" android:progressBackgroundTint="#D8F3DC" />
                </RelativeLayout>

                <!-- Row: Cancelled -->
                <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:id="@+id/badgeCancelled" android:layout_width="70dp" android:layout_height="wrap_content" android:text="Cancelled" android:gravity="center" android:padding="4dp" android:textSize="10sp" android:background="@drawable/bg_badge_cancelled" android:textColor="#721C24"/>
                    <TextView android:id="@+id/tvCancelledCount" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="0" android:textColor="#1A1A1A"/>
                    <ProgressBar android:id="@+id/pbCancelled" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="8dp" android:layout_toEndOf="@id/badgeCancelled" android:layout_toStartOf="@id/tvCancelledCount" android:layout_centerVertical="true" android:layout_marginHorizontal="8dp" android:progressTint="#C0392B" android:progressBackgroundTint="#D8F3DC" />
                </RelativeLayout>
            </LinearLayout>

            <!-- SECTION C: Navigation Cards -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:columnCount="2">

                <!-- Card: Menu Items -->
                <LinearLayout
                    android:id="@+id/cardMenuManagement"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_action_btn" android:backgroundTint="#D4A017" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Menu Items" android:fontFamily="serif" android:textColor="#1A1A1A" android:textSize="15sp" />
                </LinearLayout>

                <!-- Card: Orders -->
                <LinearLayout
                    android:id="@+id/cardOrderManagement"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_action_btn" android:backgroundTint="#2D6A4F" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Orders" android:fontFamily="serif" android:textColor="#1A1A1A" android:textSize="15sp" />
                </LinearLayout>

                <!-- Card: Inventory -->
                <LinearLayout
                    android:id="@+id/cardInventory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_action_btn" android:backgroundTint="#1B4332" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Inventory" android:fontFamily="serif" android:textColor="#1A1A1A" android:textSize="15sp" />
                </LinearLayout>

                <!-- Card: Reports -->
                <LinearLayout
                    android:id="@+id/cardReports"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_admin_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <View android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_action_btn" android:backgroundTint="#378ADD" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Reports" android:fontFamily="serif" android:textColor="#1A1A1A" android:textSize="15sp" />
                </LinearLayout>
            </GridLayout>

            <!-- SECTION D: Recent Orders -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Orders"
                    android:textColor="#1B4332"
                    android:textSize="16sp"
                    android:fontFamily="serif"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvViewAllOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="View All"
                    android:textColor="#D4A017"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/recentOrdersContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
