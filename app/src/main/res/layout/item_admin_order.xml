<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/bg_admin_card"
    android:orientation="horizontal">

    <!-- Left Status Color Bar -->
    <View
        android:id="@+id/viewAccent"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="#D4A017" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvOrderId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:text="#ORD1001"
                android:textColor="#D4A017"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="14 Mar | 09:15 AM"
                android:textColor="#5A5A5A"
                android:textSize="11sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvStudentInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Student Name (S001)"
            android:textColor="#1A1A1A"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvItemsSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Samosa x2, Masala Chai x1"
            android:textColor="#5A5A5A"
            android:textSize="12sp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="₹145"
                android:textColor="#1B4332"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatusBadge"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_badge_pending"
                android:gravity="center"
                android:paddingVertical="4dp"
                android:text="Pending"
                android:textColor="#1A1A1A"
                android:textSize="11sp" />
        </RelativeLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnView"
        android:layout_width="60dp"
        android:layout_height="32dp"
        android:layout_gravity="center_vertical"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_action_btn"
        android:padding="0dp"
        android:text="View"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="12sp" />

</LinearLayout>
